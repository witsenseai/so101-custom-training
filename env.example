export ROBOT_LEADER_PORT=/dev/ttyACM1
export ROBOT_FOLLOWER_PORT=/dev/ttyACM0
export TASK_NAME=container_door_retainer_catch
export TASK_DESC="Rotate retainer pin to unlock container door latch"
export DATASET_REPO=${HF_USER}/so101_${TASK_NAME}
